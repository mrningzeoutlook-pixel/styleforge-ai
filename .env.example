# AI Service API Keys
# Get your keys from:
# - OpenAI: https://platform.openai.com/api-keys
# - Replicate: https://replicate.com/account/api-tokens

OPENAI_API_KEY=sk-your_openai_key_here
REPLICATE_API_TOKEN=r8_your_replicate_token_here

# Optional: Custom API endpoints (for proxies, etc.)
OPENAI_BASE_URL=https://api.openai.com/v1

# Output Settings
OUTPUT_DIR=./output
TEMP_DIR=./temp
LOG_LEVEL=INFO
LOG_FILE=./logs/styleforge.log

# Platform Settings
DEFAULT_PLATFORMS=xiaohongshu,douyin
ENABLE_VIDEO_GENERATION=true
NUM_VARIANTS=3

# Image Generation Settings
IMAGE_QUALITY=hd
IMAGE_SIZE=1024x1024
IMAGE_STYLE=vivid

# Video Generation Settings
VIDEO_FPS=30
VIDEO_CODEC=libx264
VIDEO_AUDIO_CODEC=aac

# Advanced: Model Configuration
OPENAI_MODEL=gpt-4-vision-preview
REPLICATE_MODEL=stability-ai/sdxl:7762fd07cf39d81e5abe9837a9d3adf3b7902fUSION

# Performance Settings
MAX_CONCURRENT_REQUESTS=5
REQUEST_TIMEOUT=120
RETRY_ATTEMPTS=3

# Webhook (optional): For async processing notifications
WEBHOOK_URL=https://your-server.com/webhook
WEBHOOK_SECRET=your_webhook_secret_here
